package templates

import (
	"fmt"
	"strings"

	"github.com/boozedog/smoovtask/internal/ticket"
)

func priorityClass(p ticket.Priority) string {
	return "badge badge-xs st-priority-" + strings.ToLower(string(p))
}

func statusClass(s ticket.Status) string {
	return "st-status-" + strings.ToLower(string(s))
}

func statusBadgeClass(s ticket.Status) string {
	switch s {
	case ticket.StatusDone:
		return "st-status-badge-done"
	case ticket.StatusCancelled:
		return "st-status-badge-cancelled"
	case ticket.StatusBlocked, ticket.StatusRework:
		return "badge-error"
	case ticket.StatusInProgress, ticket.StatusReview:
		return "badge-primary"
	case ticket.StatusHumanReview:
		return "badge-secondary"
	default:
		return "badge-secondary"
	}
}

func statusLabel(s ticket.Status) string {
	switch s {
	case ticket.StatusReview:
		return "REVIEW"
	case ticket.StatusHumanReview:
		return "HUMAN REVIEW"
	}
	return string(s)
}

func showWorkflowBadge(tk *ticket.Ticket) bool {
	if tk == nil {
		return false
	}
	return tk.Status == ticket.StatusRework
}

func workflowBadgeClass(s ticket.Status) string {
	if s == ticket.StatusRework {
		return "badge badge-xs badge-error"
	}
	return "badge badge-xs badge-secondary"
}

func workflowBadgeLabel(s ticket.Status) string {
	if s == ticket.StatusRework {
		return "REWORK"
	}
	return ""
}

func shortAssignee(s string) string {
	if s == "" {
		return ""
	}
	// Truncate UUIDs to first 8 chars.
	if len(s) > 8 && s[8] == '-' {
		return s[:8]
	}
	// Handle prefixed formats like ses_..., prefix_value
	if idx := strings.Index(s, "_"); idx > 0 && idx < len(s)-1 {
		value := s[idx+1:]
		if len(value) >= 8 {
			return value[:8]
		}
		return value // if value <8, show full
	}
	// Fallback: if longer than 12 chars, truncate to 8 with ellipsis
	if len(s) > 12 {
		return s[:8] + "..."
	}
	return s
}

const assigneePillGray = "#6b7280"
const assigneePillText = "#111827"

func showAssignee(tk *ticket.Ticket) bool {
	return tk.Assignee != "" &&
		(tk.Status == ticket.StatusInProgress || tk.Status == ticket.StatusReview)
}

func showSourceBadge(tk *ticket.Ticket, source string) bool {
	if tk == nil || source == "" {
		return false
	}

	switch tk.Status {
	case ticket.StatusInProgress, ticket.StatusReview:
		return true
	default:
		return false
	}
}

func sourceLabel(source string) string {
	switch source {
	case "claude":
		return "Claude"
	case "opencode":
		return "OpenCode"
	case "pi":
		return "PI"
	default:
		return "Unknown"
	}
}

func sessionPillTitle(sessionID string, source string) string {
	label := sourceLabel(source)
	if sessionID == "" {
		return "Session: unknown\nSource: " + label + "\nLast hook: waiting for activity"
	}
	return "Session: " + sessionID + "\nSource: " + label + "\nLast hook: waiting for activity"
}

func stalledIconClass(stalled bool) string {
	if stalled {
		return "st-stalled-icon st-alert-active"
	}
	return "st-stalled-icon"
}

templ StalledIcon(runID string, ticketID string, lastHookUnixMs int64, stalled bool) {
	<span class={ stalledIconClass(stalled) } data-run-id={ runID } data-ticket-id={ ticketID } data-last-hook-ts-ms={ fmt.Sprintf("%d", lastHookUnixMs) } title="Stalled agent — no hooks for 2+ minutes" aria-label="Stalled agent warning">
		<svg width="12" height="12" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><polygon points="8,1 11,1.8 14.2,5 15,8 14.2,11 11,14.2 8,15 5,14.2 1.8,11 1,8 1.8,5 5,1.8" fill="#ef4444" stroke="#dc2626" stroke-width="1"/><rect x="4.1" y="7.2" width="7.8" height="1.6" rx="0.8" fill="#ffffff"/></svg>
	</span>
}

templ PriorityBadge(p ticket.Priority) {
	<span class={ priorityClass(p) }>{ string(p) }</span>
}

templ StatusBadge(s ticket.Status) {
	<span class={ "badge badge-xs " + statusBadgeClass(s) }>
		{ statusLabel(s) }
	</span>
}

templ SourceBadge(source string) {
	if source != "" {
		<span class="inline-flex items-center gap-1 opacity-70" title={ sourceLabel(source) }>
			if source == "claude" {
				<img src="/static/claude-crab.png" alt="Claude" class="st-source-badge-image"/>
			} else if source == "opencode" {
				<img src="/static/opencode-logo.png" alt="OpenCode" class="st-source-badge-image"/>
			} else if source == "pi" {
				<span class="text-xs opacity-70 font-mono uppercase">pi</span>
			} else {
				<span class="text-xs opacity-70 font-mono uppercase">?</span>
			}
		</span>
	}
}

templ TicketCard(tk *ticket.Ticket, source string, stalled bool, lastHookUnixMs int64) {
	<a href={ templ.SafeURL(fmt.Sprintf("/ticket/%s", tk.ID)) } hx-get={ fmt.Sprintf("/partials/ticket/%s", tk.ID) } hx-target="#ticket-modal-body" class="card card-xs bg-base-200 card-body st-ticket-card">
		if tk.Status == ticket.StatusHumanReview {
			<span class="badge badge-xs badge-secondary st-card-corner-badge">Human</span>
		}
		<div class="st-card-project text-xs opacity-50">{ tk.Project }</div>
		<div class="card-title st-card-title">{ tk.Title }</div>
		<div class="st-ticket-meta opacity-70 flex gap-2 items-center">
			@PriorityBadge(tk.Priority)
			if showWorkflowBadge(tk) {
				<span class={ workflowBadgeClass(tk.Status) }>{ workflowBadgeLabel(tk.Status) }</span>
			}
			<span class="text-xs font-mono opacity-80">{ tk.ID }</span>
		</div>
		if showSourceBadge(tk, source) || showAssignee(tk) {
			<div class="st-ticket-footer flex items-center gap-2">
				if showAssignee(tk) {
					<span class="st-assignee-wrap">
						@StalledIcon(tk.Assignee, tk.ID, lastHookUnixMs, stalled)
						<span class="st-alert-icon" data-run-id={ tk.Assignee } data-ticket-id={ tk.ID } title="Permission requested — agent is waiting for input" aria-label="Permission request alert">
							<svg width="12" height="12" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 14h14L8 1z" fill="#f59e0b" stroke="#b45309" stroke-width="1"/><text x="8" y="12.5" text-anchor="middle" fill="#000" font-size="9" font-weight="bold">!</text></svg>
						</span>
						<span class="st-session-dot" data-run-id={ tk.Assignee } data-ticket-id={ tk.ID } data-last-hook-ts-ms={ fmt.Sprintf("%d", lastHookUnixMs) } title="Pulses when this assignee emits hook events" aria-label="Agent hook activity indicator"></span>
						<span
							title={ sessionPillTitle(tk.Assignee, source) }
							class="st-assignee-pill rounded-full text-sm"
							style={ "--st-assignee-bg: " + assigneePillGray + "; color: " + assigneePillText + ";" }
							data-run-id={ tk.Assignee }
							data-ticket-id={ tk.ID }
							data-session-id={ tk.Assignee }
							data-source-label={ sourceLabel(source) }
						>{ shortAssignee(tk.Assignee) }</span>
						if showSourceBadge(tk, source) {
							@SourceBadge(source)
						}
					</span>
				} else if showSourceBadge(tk, source) {
					@SourceBadge(source)
				}
			</div>
		}
	</a>
}
